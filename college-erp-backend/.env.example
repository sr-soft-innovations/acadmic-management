# G.P. College of Pharmacy ERP - Environment Variables
# Copy to .env and adjust for your environment

# === Security ===
JWT_SECRET=change-me-in-production-use-long-random-string
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-domain.com

# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPER=true
PASSWORD_REQUIRE_LOWER=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_MAX_AGE_DAYS=90
PASSWORD_HISTORY_COUNT=3

# Account lock (brute-force protection)
MAX_FAILED_ATTEMPTS=5
LOCK_DURATION_MINUTES=30

# Rate limiting (login attempts per IP)
LOGIN_RATE_LIMIT_PER_IP=10
LOGIN_RATE_LIMIT_WINDOW_SEC=300

# Session
SESSION_TIMEOUT_MINUTES=15
MAX_SESSIONS_PER_USER=5

# CAPTCHA (Google reCAPTCHA v2/v3) - leave empty to disable
RECAPTCHA_SECRET_KEY=

# OTP
OTP_EXPIRE_MINUTES=10

# Dev only: log OTP codes (set to 1/true/yes for development)
LOG_OTP_DEV=
